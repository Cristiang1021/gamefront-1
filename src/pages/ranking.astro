---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Ranking | VR Scoreboard">
  <div class="container animate-in">
    <h1>Clasificación</h1>
    <p class="subtitle">Los mejores puntajes del evento.</p>

    <!-- Filtros Superiores -->
    <div class="filters-stack">
      <div class="filter-group">
        <label>Rango de Tiempo</label>
        <div class="segmented-control" id="range-filter">
          <button class="active" data-value="hoy">Hoy</button>
          <button data-value="ayer">Ayer</button>
          <button data-value="general">General</button>
        </div>
      </div>

      <div class="filter-group">
        <label>Tipo de Participante</label>
        <div class="segmented-control" id="type-filter">
          <button class="active" data-value="todos">Todos</button>
          <button data-value="clientes">Clientes</button>
          <button data-value="visitantes">Invitados</button>
        </div>
      </div>
    </div>

    <div id="ranking-content">
      <div id="podium" class="podium-modern"></div>
      <div id="list" class="list-modern"></div>
    </div>

    <div id="loading-state" class="state-msg">Cargando ranking...</div>
    <div id="empty-state" class="empty-state" style="display:none">
      <p>No hay datos con los filtros seleccionados.</p>
    </div>
    <div id="error-state" class="state-msg error" style="display:none">
      Ocurrió un error al cargar los datos. Intenta nuevamente.
    </div>

    <div class="pagination">
      <button class="btn btn-ghost" id="prev-page">Anterior</button>
      <span id="page-num">Página 1</span>
      <button class="btn btn-ghost" id="next-page">Siguiente</button>
    </div>
  </div>

  <style>
    .filters-stack { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
    .filter-group { display: flex; flex-direction: column; gap: 8px; }
    .filter-group label { color: var(--text-muted); font-size: 12px; }

    .podium-modern { display: flex; flex-direction: column; gap: 8px; margin-bottom: 14px; }
    
    :global(.rank-card-premium) {
      display: grid;
      grid-template-columns: 48px 1fr auto;
      align-items: center;
      gap: 12px;
      padding: 14px;
      background: var(--surface);
      border-radius: 12px;
      box-shadow: var(--ring) 0 0 0 1px;
    }

    :global(.rank-card-premium.top-1) {
      box-shadow: var(--ring) 0 0 0 2px;
    }

    :global(.pos-indicator) {
      font-size: 16px;
      font-weight: 700;
      width: 34px;
      height: 34px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.1);
    }

    :global(.top-1 .pos-indicator) { background: #ffffff; color: #000000; }

    :global(.player-name) { font-size: 15px; font-weight: 600; color: var(--text); }
    :global(.player-meta) { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

    :global(.score-val) { font-size: 22px; font-weight: 700; color: var(--text); font-variant-numeric: tabular-nums; }
    :global(.top-1 .score-val) { color: var(--accent); }

    .list-modern { display: flex; flex-direction: column; gap: 6px; }
    
    :global(.rank-row-modern) {
      display: grid;
      grid-template-columns: 40px 1fr auto;
      align-items: center;
      padding: 12px 14px;
      border-radius: 10px;
      box-shadow: var(--ring) 0 0 0 1px;
      background: #050505;
    }

    :global(.rank-row-modern:hover) { box-shadow: var(--ring) 0 0 0 2px; }
    :global(.row-pos) { font-weight: 700; color: var(--text-muted); }
    :global(.row-name) { font-weight: 600; }
    :global(.row-doc) { font-size: 11px; color: var(--text-muted); }
    :global(.row-score) { font-weight: 700; font-size: 17px; }

    .pagination {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 18px;
      padding-top: 12px;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
    }

    .empty-state { text-align: center; padding: 40px 0; color: var(--text-muted); font-weight: 500; }
    .state-msg {
      margin: 10px 0;
      padding: 12px 14px;
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: rgba(255, 255, 255, 0.08);
      color: var(--text-muted);
      font-weight: 600;
      text-align: center;
    }
    .state-msg.error {
      border-color: rgba(248, 113, 113, 0.45);
      color: #fecaca;
      background: rgba(248, 113, 113, 0.1);
    }

    .animate-in { animation: slideUp 0.4s ease-out forwards; }
    @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  </style>

  <script>
    const API = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8000";
    const fmt = (v: any) => new Intl.NumberFormat("es-EC").format(v || 0);

    class RankingApp {
      mode = "hoy";
      type = "todos";
      page = 0;

      constructor() {
        this.init();
      }

      async init() {
        this.bindEvents();
        await this.load();
      }

      bindEvents() {
        document.getElementById("range-filter")?.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest("button");
          if (!btn) return;
          this.mode = btn.dataset.value!;
          this.updateActive("range-filter", btn);
          this.page = 0;
          this.load();
        });

        document.getElementById("type-filter")?.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest("button");
          if (!btn) return;
          this.type = btn.dataset.value!;
          this.updateActive("type-filter", btn);
          this.page = 0;
          this.load();
        });

        document.getElementById("prev-page")?.addEventListener("click", () => {
          if (this.page > 0) { this.page--; this.load(); }
        });

        document.getElementById("next-page")?.addEventListener("click", () => {
          this.page++; this.load();
        });
      }

      updateActive(parentId: string, activeBtn: HTMLElement) {
        document.querySelectorAll(`#${parentId} button`).forEach(b => b.classList.remove("active"));
        activeBtn.classList.add("active");
      }

      async load() {
        const podium = document.getElementById("podium")!;
        const list = document.getElementById("list")!;
        const empty = document.getElementById("empty-state")!;
        const loading = document.getElementById("loading-state")!;
        const error = document.getElementById("error-state")!;
        loading.style.display = "block";
        error.style.display = "none";
        empty.style.display = "none";
        
        let clientParam = "";
        if (this.type === "clientes") clientParam = "&is_cliente=true";
        if (this.type === "visitantes") clientParam = "&is_cliente=false";

        try {
          const skip = this.page * 10;
          const r = await fetch(`${API}/api/ranking/${this.mode}?limit=10&skip=${skip}${clientParam}`);
          const d = await r.json();
          const items = d.data || [];
          loading.style.display = "none";

          document.getElementById("page-num")!.textContent = `Página ${this.page + 1}`;

          if (items.length === 0) {
            podium.innerHTML = ""; list.innerHTML = "";
            empty.style.display = "block"; return;
          }
          empty.style.display = "none";

          if (this.page === 0) {
            podium.innerHTML = items.slice(0, 3).map((item: any, i: number) => `
              <div class="rank-card-premium ${i === 0 ? "top-1" : ""} animate-in" style="animation-delay: ${i * 0.1}s">
                <div class="pos-indicator">${i + 1}</div>
                <div>
                  <div class="player-name">${item.nombre}</div>
                  <div class="player-meta">${item.cedula} • ${item.is_cliente ? "Cliente" : "Invitado"}</div>
                </div>
                <div class="score-val">${fmt(item.puntaje)}</div>
              </div>
            `).join("");
            list.innerHTML = items.slice(3).map((item: any, i: number) => this.renderRow(item, i + 4)).join("");
          } else {
            podium.innerHTML = "";
            list.innerHTML = items.map((item: any, i: number) => this.renderRow(item, skip + i + 1)).join("");
          }
        } catch {
          loading.style.display = "none";
          podium.innerHTML = "";
          list.innerHTML = "";
          error.style.display = "block";
        }
      }

      renderRow(item: any, pos: number) {
        return `
          <div class="rank-row-modern animate-in">
            <div class="row-pos">${pos}</div>
            <div>
              <div class="row-name">${item.nombre} ${item.is_cliente ? "• Cliente" : ""}</div>
              <div class="row-doc">${item.cedula}</div>
            </div>
            <div class="row-score">${fmt(item.puntaje)}</div>
          </div>
        `;
      }
    }

    window.addEventListener("DOMContentLoaded", () => new RankingApp());
  </script>
</MainLayout>
