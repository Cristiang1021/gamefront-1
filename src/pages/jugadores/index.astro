---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Jugadores | VR Scoreboard">
  <h1 class="page-title">Jugadores</h1>
  <p class="page-subtitle">Listado y búsqueda por nombre o cédula.</p>

  <section class="card">
    <form id="search-form" style="margin-bottom: 14px;">
      <label>
        Buscar jugador
        <input
          id="search-input"
          type="text"
          placeholder="Ej: Juan o 0601234567"
          autocomplete="off"
        />
      </label>
      <div class="actions">
        <button type="submit" class="btn btn-primary">Buscar</button>
        <button id="reset-btn" type="button" class="btn btn-secondary">Limpiar</button>
      </div>
    </form>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Cédula</th>
            <th>Teléfono</th>
            <th>Cliente</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="jugadores-body"></tbody>
      </table>
    </div>
    <div id="jugadores-status" class="status" style="display:none; margin-top: 10px;"></div>
    <div id="jugador-detalle-inline" class="card" style="display:none; margin-top: 12px;"></div>
  </section>

  <script>
    const API_BASE = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8000";
    const form = document.getElementById("search-form");
    const input = document.getElementById("search-input");
    const resetBtn = document.getElementById("reset-btn");
    const body = document.getElementById("jugadores-body");
    const statusBox = document.getElementById("jugadores-status");
    const detalleBox = document.getElementById("jugador-detalle-inline");
    const formatNumber = (value) => new Intl.NumberFormat("es-EC").format(value || 0);

    function renderRows(items) {
      if (!items.length) {
        body.innerHTML = `<tr><td colspan="6" class="muted">No se encontraron jugadores.</td></tr>`;
        return;
      }
      body.innerHTML = items
        .map(
          (item) => `
            <tr>
              <td>${item.id}</td>
              <td>${item.nombre}</td>
              <td>${item.cedula}</td>
              <td>${item.telefono}</td>
              <td>${item.is_cliente ? "Sí" : "No"}</td>
              <td><button class="btn btn-secondary" data-detalle-id="${item.id}">Ver detalle</button></td>
            </tr>
          `
        )
        .join("");
    }

    async function loadDetalleJugador(jugadorId) {
      try {
        const response = await fetch(`${API_BASE}/api/jugadores/${jugadorId}`);
        const result = await response.json();
        if (!response.ok || !result.success) {
          throw new Error(result.message || "No se pudo cargar el detalle");
        }
        const j = result.data;
        detalleBox.style.display = "block";
        detalleBox.innerHTML = `
          <h3 style="margin-top:0;">Detalle jugador</h3>
          <div><strong>${j.nombre}</strong> - ${j.cedula}</div>
          <div class="muted" style="margin-top:4px;">Teléfono: ${j.telefono} | Cliente: ${j.is_cliente ? "Sí" : "No"}</div>
          <div style="margin-top:8px;">Mejor puntaje: <strong>${formatNumber(j.mejor_puntaje)}</strong> | Partidas: <strong>${j.cantidad_partidas}</strong></div>
        `;
      } catch (error) {
        detalleBox.style.display = "block";
        detalleBox.innerHTML = `<div class="status error">${error.message || "Error de red"}</div>`;
      }
    }

    async function loadJugadores(query = "") {
      statusBox.style.display = "none";
      const searchParams = new URLSearchParams();
      if (query.trim()) searchParams.set("q", query.trim());
      const url = `${API_BASE}/api/jugadores${searchParams.toString() ? `?${searchParams}` : ""}`;
      try {
        const response = await fetch(url);
        const result = await response.json();
        if (!response.ok || !result.success) {
          throw new Error(result.message || "No se pudo cargar la lista");
        }
        renderRows(result.data || []);
      } catch (error) {
        body.innerHTML = "";
        statusBox.style.display = "block";
        statusBox.className = "status error";
        statusBox.textContent = error.message || "Error de red";
      }
    }

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      loadJugadores(input.value);
    });

    resetBtn.addEventListener("click", () => {
      input.value = "";
      loadJugadores("");
      detalleBox.style.display = "none";
    });

    body.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const id = target.getAttribute("data-detalle-id");
      if (id) loadDetalleJugador(id);
    });

    loadJugadores();
  </script>
</MainLayout>
